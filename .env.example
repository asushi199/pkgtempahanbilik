# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Global signing secret for admin sessions, approval tokens, and admin
# password hashes. Use one strong random value; do NOT change it after
# admin passwords have been set, or existing passwords stop matching.
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret

# Optional. Public base URL used to build approval links in WhatsApp messages.
# If unset, it is derived from the request headers.
APP_BASE_URL=https://your-deployment.vercel.app
