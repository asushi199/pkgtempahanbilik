# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single global admin password. One login at /admin manages all PKGs.
ADMIN_PASSWORD=change-this-admin-password

# Signing secret for admin session cookies and booking approval tokens.
# Use one strong random value.
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret

# Optional. Public base URL used to build approval links in WhatsApp messages.
# If unset, it is derived from the request headers.
APP_BASE_URL=https://your-deployment.vercel.app
